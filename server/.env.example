DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/eixo?schema=public"
# Obrigatório em produção. Use um segredo forte e exclusivo.
SESSION_TOKEN_SALT="troque-por-um-segredo-forte"
SESSION_TTL_MS="86400000"
SESSION_REMEMBER_TTL_MS="2592000000"
# Em produção, aponte para as origens reais do frontend, separadas por vírgula.
CORS_ORIGIN="http://localhost:5173"
# Apenas para desenvolvimento local. Nunca ativar em produção.
ALLOW_X_USER_ID="false"
OTP_SEND_WINDOW_MS="600000"
OTP_SEND_MAX_PER_IP="5"
OTP_SEND_MAX_PER_PHONE="3"
OTP_VERIFY_WINDOW_MS="600000"
OTP_VERIFY_MAX_PER_IP="10"
OTP_VERIFY_MAX_PER_PHONE="5"
GOOGLE_API_KEY="SUA_CHAVE_API_AQUI"
TWILIO_ACCOUNT_SID="SEU_TWILIO_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="SEU_TWILIO_AUTH_TOKEN"
TWILIO_VERIFY_SID="SEU_TWILIO_VERIFY_SID"
ADMIN_EMAIL="admin@seudominio.com"

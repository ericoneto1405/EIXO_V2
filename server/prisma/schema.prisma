model ExternalOperation {
  id                String                           @id
  farmId            String
  createdById       String
  code              String
  title             String
  partnerName       String
  partnerDocument   String?
  partnerRoleLabel  String?
  operationNature   ExternalOperationNature
  pricingModel      ExternalPricingModel
  allocationType    ExternalAllocationType
  externalFarmName  String?
  externalFarmCity  String?
  externalFarmState String?
  externalUnitName  String?
  status            ExternalOperationStatus          @default(DRAFT)
  startDate         DateTime?
  minDays           Int?
  maxDays           Int?
  notes             String?
  createdAt         DateTime                         @default(now())
  updatedAt         DateTime                         @updatedAt
  createdBy         User                             @relation("ExternalOperationCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  farm              Farm                             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  documents         ExternalOperationDocument[]
  ledgerEntries     ExternalOperationLedgerEntry[]
  lots              ExternalOperationLot[]
  responsibilities  ExternalOperationResponsibility?
  rules             ExternalOperationRule?
  settlements       ExternalOperationSettlement[]

  @@unique([farmId, code])
  @@index([farmId, status])
}

model ExternalOperationDocument {
  id          String                        @id
  operationId String
  type        ExternalOperationDocumentType

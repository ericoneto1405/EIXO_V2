generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                             String                         @id @default(uuid())
  name                           String
  email                          String                         @unique
  password                       String
  modules                        String[]
  roles                          String[]                       @default([])
  lastFarmId                     String?
  activeOrganizationId           String?
  createdAt                      DateTime                       @default(now())
  cnpjData                       Json?
  document                       String?
  documentType                   String?
  phone                          String?
  termsAcceptedAt                DateTime?
  termsVersion                   String?
  onboardingCompletedAt          DateTime?
  accessType                     AppAccessType                  @default(WEB)
  appActivationStatus            AppActivationStatus?
  fieldProfile                   FieldProfile?
  acasalamentoSessions           AcasalamentoSession[]          @relation("AcasalamentoSessionCreatedBy")
  activityLogs                   ActivityLog[]
  appActivationCodes             AppActivationCode[]
  appDevices                     AppDevice[]
  externalOperations             ExternalOperation[]            @relation("ExternalOperationCreatedBy")
  externalOperationLedgerEntries ExternalOperationLedgerEntry[] @relation("ExternalOperationLedgerCreatedBy")
  externalOperationSettlements   ExternalOperationSettlement[]  @relation("ExternalOperationSettlementCreatedBy")
  farms                          Farm[]
  feedlotContracts               FeedlotContract[]              @relation("FeedlotContractCreatedBy")
  feedlotLedgerEntries           FeedlotLedgerEntry[]           @relation("FeedlotLedgerCreatedBy")
  feedlotSettlements             FeedlotSettlement[]            @relation("FeedlotSettlementCreatedBy")
  fieldOccurrences               FieldOccurrence[]              @relation("FieldOccurrenceCreatedBy")
  geneticsAnalysisRuns           GeneticsAnalysisRun[]          @relation("GeneticsAnalysisCreatedBy")
  memberships                    OrganizationMembership[]
  passwordResetTokens            PasswordResetToken[]
  sessions                       Session[]
  activeOrganization             Organization?                  @relation("ActiveOrganization", fields: [activeOrganizationId], references: [id])
  farmAccesses                   UserFarmAccess[]
  reproCheckupSessions           ReproCheckupSession[]          @relation("ReproCheckupCreatedBy")

  @@index([phone])
}

model Farm {
  id                      String                   @id @default(uuid())
  name                    String
  city                    String
  lat                     Float?
  lng                     Float?
  mapAssetPath            String?
  mapData                 Json?
  size                    Float
  notes                   String?
  organizationId          String?
  createdAt               DateTime                 @default(now())
  reproMode               ReproMode                @default(CONTINUO)
  userId                  String
  responsibleName         String?                  @map("responsible_name")
  acasalamentoSessions    AcasalamentoSession[]
  accountCategories       AccountCategory[]
  animals                 Animal[]
  breeds                  Breed[]
  seasons                 BreedingSeason[]
  criaMortalities         CriaMortality[]
  embryoBatches           EmbryoBatch[]
  externalOperations      ExternalOperation[]
  organization            Organization?            @relation(fields: [organizationId], references: [id])
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedlotContracts        FeedlotContract[]
  fieldOccurrences        FieldOccurrence[]
  financialPayables       FinancialPayable[]
  financialReceivables    FinancialReceivable[]
  financialTransactions   FinancialTransaction[]
  geneticsAnalysisRuns    GeneticsAnalysisRun[]
  herdCategoryTargets     HerdCategoryTarget[]
  herdEvents              HerdEvent[]
  herdImportPendings      HerdImportPending[]
  herdSettings            HerdSettings?
  lots                    Lot[]
  nutritionAssignments    NutritionAssignment[]
  nutritionCostEntries    NutritionCostEntry[]
  nutritionExecutions     NutritionExecution[]
  nutritionFabrications   NutritionFabrication[]
  nutritionIngredients    NutritionIngredient[]
  nutritionPhases         NutritionPhase[]
  nutritionPlans          NutritionPlan[]
  nutritionPreparedFeeds  NutritionPreparedFeed[]
  nutritionSettings       NutritionSettings?
  nutritionTroughReadings NutritionTroughReading[]
  nutritionUnits          NutritionUnit[]
  paddocks                Paddock[]
  paddockMoves            PaddockMove[]
  poAnimals               PoAnimal[]
  poLots                  PoLot[]
  poWeighings             PoWeighing[]
  reproEvents             ReproEvent[]
  sanitaryRecords         SanitaryRecord[]
  selectionDecisions      SelectionDecision[]
  semenBatches            SemenBatch[]
  userAccesses            UserFarmAccess[]
  weighingSessions        WeighingSession[]
  reproCheckupRecords     ReproCheckupRecord[]
  reproCheckupSessions    ReproCheckupSession[]

  @@index([userId])
  @@index([organizationId])
}

model Paddock {
  id               String            @id @default(uuid())
  name             String
  areaHa           Float?            @map("size")
  capacity         Float?
  lat              Float?
  lng              Float?
  mapGeometry      Json?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  farmId           String
  divisionType     String?           @map("division_type")
  forrageira       String?
  lotacaoUaHa      Float?
  currentAnimals   Animal[]          @relation("AnimalCurrentPaddock")
  fieldOccurrences FieldOccurrence[]
  farm             Farm              @relation(fields: [farmId], references: [id], onDelete: Cascade)
  paddockMoves     PaddockMove[]
  currentPoAnimals PoAnimal[]        @relation("PoAnimalCurrentPaddock")

  @@index([farmId])
}

model Lot {
  id                   String                @id @default(uuid())
  name                 String
  notes                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  farmId               String
  objective            String?
  phase                String?
  startDate            DateTime?
  status               String                @default("ATIVO")
  animals              Animal[]
  farm                 Farm                  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  nutritionAssignments NutritionAssignment[]
  nutritionCostEntries NutritionCostEntry[]
  nutritionExecutions  NutritionExecution[]
  nutritionUnits       NutritionUnit[]

  @@index([farmId])
}

model Animal {
  id                   String                @id @default(uuid())
  brinco               String
  registro             String?
  identityKey          String
  raca                 String?
  tipoCadastro         AnimalTipoCadastro    @default(MESTICO)
  sexo                 AnimalSexo?
  categoria            String?
  dataNascimento       DateTime?
  pesoAtual            Float?
  gmd                  Float?
  gmd30                Float?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  farmId               String
  lotId                String?
  currentPaddockId     String?
  maeId                String?
  maeNome              String?
  paiId                String?
  paiNome              String?
  sisbov               String?
  tatuagem             String?
  currentPaddock       Paddock?              @relation("AnimalCurrentPaddock", fields: [currentPaddockId], references: [id], onDelete: Restrict)
  farm                 Farm                  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  lot                  Lot?                  @relation(fields: [lotId], references: [id])
  mae                  Animal?               @relation("AnimalMae", fields: [maeId], references: [id])
  filhosMae            Animal[]              @relation("AnimalMae")
  pai                  Animal?               @relation("AnimalPai", fields: [paiId], references: [id])
  filhosPai            Animal[]              @relation("AnimalPai")
  criaMortalities      CriaMortality[]
  exposures            Exposure[]
  fieldOccurrences     FieldOccurrence[]
  herdEvents           HerdEvent[]
  nutritionAssignments NutritionAssignment[]
  paddockMoves         PaddockMove[]
  reproEvents          ReproEvent[]
  sanitaryRecords      SanitaryRecord[]
  selectionDecisions   SelectionDecision[]
  pesagens             Weighing[]
  reproCheckupRecords  ReproCheckupRecord[]
  semenBatches         SemenBatch[]          @relation("SemenBullAnimal")
  embryoDonorBatches   EmbryoBatch[]         @relation("EmbryoDonorAnimal")
  embryoSireBatches    EmbryoBatch[]         @relation("EmbryoSireAnimal")

  @@unique([farmId, identityKey])
  @@index([farmId, brinco])
  @@index([farmId, registro])
  @@index([farmId])
  @@index([lotId])
  @@index([currentPaddockId])
  @@index([maeId])
  @@index([paiId])
}

model Weighing {
  id                String                    @id @default(uuid())
  data              DateTime
  peso              Float
  gmd               Float
  source            WeighingSource            @default(MANUAL)
  provider          ScaleIntegrationProvider?
  rawPayload        String?
  createdAt         DateTime                  @default(now())
  animalId          String
  scaleSessionId    String?                   @unique
  weighingSessionId String?
  animal            Animal                    @relation(fields: [animalId], references: [id], onDelete: Cascade)
  weighingSession   WeighingSession?          @relation(fields: [weighingSessionId], references: [id])

  @@unique([animalId, data])
  @@index([weighingSessionId])
}

model WeighingSession {
  id              String     @id @default(uuid())
  name            String
  farmId          String
  createdAt       DateTime   @default(now())
  responsibleName String?
  weighings       Weighing[]
  farm            Farm       @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId])
}

model CriaMortality {
  id         String    @id
  farmId     String
  animalId   String?
  poAnimalId String?
  category   String
  cause      String
  date       DateTime
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  animal     Animal?   @relation(fields: [animalId], references: [id])
  farm       Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  poAnimal   PoAnimal? @relation(fields: [poAnimalId], references: [id])

  @@index([animalId])
  @@index([farmId, date])
  @@index([poAnimalId])
}

model Session {
  id        String     @id @default(uuid())
  userId    String
  tokenHash String     @unique
  createdAt DateTime   @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  deviceId  String?
  device    AppDevice? @relation(fields: [deviceId], references: [id])
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
}

model Organization {
  id                   String                           @id @default(uuid())
  name                 String
  slug                 String                           @unique
  billingProvider      BillingProvider                  @default(INTERNAL)
  billingCustomerId    String?
  accessState          BillingAccessState               @default(ACTIVE)
  accessStateUpdatedAt DateTime                         @default(now())
  graceUntil           DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime                         @default(now())
  updatedAt            DateTime                         @updatedAt
  acasalamentoSessions AcasalamentoSession[]
  billingEvents        BillingEvent[]
  billingSubscriptions BillingSubscription[]
  farms                Farm[]
  geneticsAnalysisRuns GeneticsAnalysisRun[]
  invitations          Invitation[]
  memberships          OrganizationMembership[]
  entitlements         OrganizationProductEntitlement[]
  activeUsers          User[]                           @relation("ActiveOrganization")

  @@index([accessState])
}

model Product {
  id           String                           @id @default(uuid())
  code         String                           @unique
  name         String
  description  String?
  isActive     Boolean                          @default(true)
  createdAt    DateTime                         @default(now())
  updatedAt    DateTime                         @updatedAt
  entitlements OrganizationProductEntitlement[]
}

model OrganizationProductEntitlement {
  id             String       @id @default(uuid())
  organizationId String
  productId      String
  status         String       @default("ACTIVE")
  startedAt      DateTime     @default(now())
  endedAt        DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([organizationId, productId])
  @@index([organizationId, status])
}

model OrganizationMembership {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Invitation {
  id             String           @id @default(uuid())
  organizationId String
  email          String
  role           OrganizationRole @default(MEMBER)
  token          String           @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
}

model BreedingSeason {
  id        String       @id @default(uuid())
  farmId    String
  name      String
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  farm      Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  exposures Exposure[]
  events    ReproEvent[]

  @@index([farmId, startAt])
}

model Exposure {
  id        String         @id @default(uuid())
  seasonId  String
  animalId  String
  createdAt DateTime       @default(now())
  animal    Animal         @relation(fields: [animalId], references: [id], onDelete: Cascade)
  season    BreedingSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, animalId])
  @@index([animalId])
}

model ReproEvent {
  id        String          @id @default(uuid())
  farmId    String
  animalId  String
  type      ReproEventType
  date      DateTime
  seasonId  String?
  payload   Json?
  notes     String?
  bullId    String?
  protocol  String?
  createdAt DateTime        @default(now())
  animal    Animal          @relation(fields: [animalId], references: [id], onDelete: Cascade)
  farm      Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  season    BreedingSeason? @relation(fields: [seasonId], references: [id])

  @@index([animalId, date])
  @@index([farmId, date])
  @@index([seasonId])
}

model SelectionDecision {
  id        String                @id @default(uuid())
  farmId    String
  animalId  String
  decision  SelectionDecisionType
  reason    String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  animal    Animal                @relation(fields: [animalId], references: [id], onDelete: Cascade)
  farm      Farm                  @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([farmId, animalId])
  @@index([animalId])
  @@index([farmId])
}

model PoAnimal {
  id                   String                @id @default(uuid())
  farmId               String
  brinco               String?
  nome                 String
  raca                 String
  sexo                 AnimalSexo
  dataNascimento       DateTime?
  pesoAtual            Float                 @default(0)
  gmd                  Float?
  gmd30                Float?
  lotId                String?
  currentPaddockId     String
  registro             String?
  categoria            String?
  observacoes          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  criaMortalities      CriaMortality[]
  embryoDonorBatches   EmbryoBatch[]         @relation("EmbryoDonor")
  embryoSireBatches    EmbryoBatch[]         @relation("EmbryoSire")
  herdEvents           HerdEvent[]
  nutritionAssignments NutritionAssignment[]
  paddockMoves         PaddockMove[]
  currentPaddock       Paddock               @relation("PoAnimalCurrentPaddock", fields: [currentPaddockId], references: [id])
  farm                 Farm                  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  lot                  PoLot?                @relation(fields: [lotId], references: [id])
  pesagens             PoWeighing[]
  sanitaryRecords      SanitaryRecord[]
  semenBatches         SemenBatch[]          @relation("SemenBull")

  @@unique([farmId, brinco])
  @@index([farmId])
  @@index([lotId])
  @@index([currentPaddockId])
}

model PoLot {
  id                   String                @id @default(uuid())
  name                 String
  notes                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  farmId               String
  nutritionAssignments NutritionAssignment[]
  nutritionCostEntries NutritionCostEntry[]
  nutritionExecutions  NutritionExecution[]
  animals              PoAnimal[]
  farm                 Farm                  @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId])
}

model PoWeighing {
  id         String   @id @default(uuid())
  data       DateTime
  peso       Float
  gmd        Float
  notes      String?
  createdAt  DateTime @default(now())
  poAnimalId String
  farmId     String
  farm       Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  poAnimal   PoAnimal @relation(fields: [poAnimalId], references: [id], onDelete: Cascade)

  @@unique([poAnimalId, data])
  @@index([poAnimalId, data])
  @@index([farmId])
  @@index([farmId, data])
}

model NutritionPlan {
  id                            String                       @id @default(uuid())
  farmId                        String
  nome                          String
  fase                          String?
  startAt                       DateTime
  endAt                         DateTime?
  metaGmd                       Float?
  observacoes                   String?
  reviewStatus                  ReviewStatus                 @default(PENDING)
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  estimatedCostPerHeadDay       Float?
  feedingSlot                   String?
  objetivo                      String?
  phaseId                       String?
  plannedIntakeDryKgPerHead     Float?
  plannedIntakeDryKgTotal       Float?
  plannedIntakeNaturalKgPerHead Float?
  plannedIntakeNaturalKgTotal   Float?
  preparedFeedId                String?
  previousVersionId             String?
  status                        NutritionPlanLifecycleStatus @default(ACTIVE)
  versionNumber                 Int                          @default(1)
  assignments                   NutritionAssignment[]
  executions                    NutritionExecution[]
  farm                          Farm                         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  phase                         NutritionPhase?              @relation(fields: [phaseId], references: [id])
  preparedFeed                  NutritionPreparedFeed?       @relation(fields: [preparedFeedId], references: [id])

  @@index([farmId])
  @@index([preparedFeedId])
  @@index([phaseId])
  @@index([status])
}

model NutritionAssignment {
  id           String         @id @default(uuid())
  farmId       String
  planId       String
  lotId        String?
  poLotId      String?
  animalId     String?
  poAnimalId   String?
  startAt      DateTime
  endAt        DateTime?
  reviewStatus ReviewStatus   @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  unitId       String?
  animal       Animal?        @relation(fields: [animalId], references: [id], onDelete: Cascade)
  farm         Farm           @relation(fields: [farmId], references: [id], onDelete: Cascade)
  lot          Lot?           @relation(fields: [lotId], references: [id], onDelete: Cascade)
  plan         NutritionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  poAnimal     PoAnimal?      @relation(fields: [poAnimalId], references: [id], onDelete: Cascade)
  poLot        PoLot?         @relation(fields: [poLotId], references: [id], onDelete: Cascade)
  unit         NutritionUnit? @relation(fields: [unitId], references: [id])

  @@index([farmId])
  @@index([planId])
  @@index([lotId])
  @@index([poLotId])
  @@index([animalId])
  @@index([poAnimalId])
  @@index([unitId])
  @@index([farmId, startAt])
}

model NutritionSettings {
  id                           String                    @id @default(uuid())
  farmId                       String                    @unique
  operationContext             NutritionOperationContext @default(PASTO)
  adjustmentMode               NutritionAdjustmentMode   @default(SUGESTAO)
  indicatorsApprovedOnly       Boolean                   @default(false)
  requireFabricationApproval   Boolean                   @default(true)
  requireExecutionApproval     Boolean                   @default(true)
  requireTroughApproval        Boolean                   @default(true)
  predictiveSafeDays           Int                       @default(7)
  predictiveWarningDays        Int                       @default(3)
  diffWarningPercent           Float                     @default(3)
  diffCriticalPercent          Float                     @default(7)
  manualReviewThresholdPercent Float                     @default(5)
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
  farm                         Farm                      @relation(fields: [farmId], references: [id], onDelete: Cascade)
}

model NutritionPhase {
  id                    String          @id @default(uuid())
  farmId                String
  name                  String
  periodStart           DateTime?
  periodEnd             DateTime?
  primaryPlanId         String?
  targetIntakeDryKgHead Float?
  targetGmd             Float?
  targetFeedConversion  Float?
  targetCostPerHeadDay  Float?
  notes                 String?
  active                Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  farm                  Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  plans                 NutritionPlan[]
  units                 NutritionUnit[]

  @@index([farmId])
  @@index([active])
}

model NutritionUnit {
  id               String                   @id @default(uuid())
  farmId           String
  lotId            String?
  phaseId          String?
  type             NutritionUnitType
  name             String
  currentHeadCount Int?
  active           Boolean                  @default(true)
  notes            String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  assignments      NutritionAssignment[]
  executions       NutritionExecution[]
  troughReadings   NutritionTroughReading[]
  farm             Farm                     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  lot              Lot?                     @relation(fields: [lotId], references: [id])
  phase            NutritionPhase?          @relation(fields: [phaseId], references: [id])

  @@index([farmId])
  @@index([lotId])
  @@index([phaseId])
  @@index([type])
}

model NutritionIngredient {
  id                      String                                @id @default(uuid())
  farmId                  String
  name                    String
  category                String
  unit                    String
  currentCost             Float
  supplier                String?
  currentDryMatterPercent Float
  dryMatterUpdatedAt      DateTime?
  currentStockNatural     Float                                 @default(0)
  minStockNatural         Float                                 @default(0)
  active                  Boolean                               @default(true)
  createdAt               DateTime                              @default(now())
  updatedAt               DateTime                              @updatedAt
  fabricationItems        NutritionFabricationItem[]
  farm                    Farm                                  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  priceHistory            NutritionIngredientCostHistory[]
  dryMatterHistory        NutritionIngredientDryMatterHistory[]
  preparedFeedItems       NutritionPreparedFeedItem[]

  @@index([farmId])
  @@index([active])
}

model NutritionIngredientCostHistory {
  id              String              @id @default(uuid())
  ingredientId    String
  cost            Float
  recordedAt      DateTime
  notes           String?
  createdByUserId String?
  createdByName   String?
  ingredient      NutritionIngredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([recordedAt])
}

model NutritionIngredientDryMatterHistory {
  id               String              @id @default(uuid())
  ingredientId     String
  dryMatterPercent Float
  recordedAt       DateTime
  notes            String?
  createdByUserId  String?
  createdByName    String?
  ingredient       NutritionIngredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([recordedAt])
}

model NutritionPreparedFeed {
  id                      String                      @id @default(uuid())
  farmId                  String
  name                    String
  expectedYieldNaturalKg  Float
  expectedYieldDryKg      Float?
  currentDryMatterPercent Float
  currentTotalCost        Float
  currentCostPerNaturalKg Float
  currentCostPerDryKg     Float?
  currentStockNatural     Float                       @default(0)
  currentStockDry         Float                       @default(0)
  status                  NutritionPreparedFeedStatus @default(ACTIVE)
  notes                   String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  executions              NutritionExecution[]
  fabrications            NutritionFabrication[]
  plans                   NutritionPlan[]
  farm                    Farm                        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  items                   NutritionPreparedFeedItem[]

  @@index([farmId])
  @@index([status])
}

model NutritionPreparedFeedItem {
  id                String                @id @default(uuid())
  preparedFeedId    String
  ingredientId      String
  proportionPercent Float
  sequence          Int                   @default(0)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  ingredient        NutritionIngredient   @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  preparedFeed      NutritionPreparedFeed @relation(fields: [preparedFeedId], references: [id], onDelete: Cascade)

  @@unique([preparedFeedId, ingredientId])
  @@index([ingredientId])
}

model NutritionFabrication {
  id                 String                     @id @default(uuid())
  farmId             String
  preparedFeedId     String
  batchCode          String
  producedAt         DateTime
  outputNaturalKg    Float
  outputDryKg        Float
  remainingNaturalKg Float
  remainingDryKg     Float
  totalCost          Float
  costPerNaturalKg   Float
  costPerDryKg       Float?
  status             NutritionFabricationStatus @default(PENDING)
  notes              String?
  createdByUserId    String?
  createdByName      String?

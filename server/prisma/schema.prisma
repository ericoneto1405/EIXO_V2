  netAmount            Float
  remainingAnimals     Int
  remainingEntryArroba Float
  notes                String?
  commercialValue      Float?
  gtaNumber            String?
  paymentTerms         String?
  calcMemory           Json
  romaneio             Json
  addendumData         Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  contract             FeedlotContract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  createdBy            User                  @relation("FeedlotSettlementCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([contractId, exitDate], map: "FeedlotSettlement_contractId_exitDate_idx")
  @@index([contractId, type], map: "FeedlotSettlement_contractId_type_idx")
}

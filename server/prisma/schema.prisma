generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                  @id @default(uuid())
  name                 String
  email                String                  @unique
  password             String
  modules              String[]
  roles                String[]                @default([])
  lastFarmId           String?
  activeOrganizationId String?
  createdAt            DateTime                @default(now())
  farms                Farm[]
  sessions             Session[]
  memberships          OrganizationMembership[]
  activityLogs         ActivityLog[]
  geneticsAnalysisRuns GeneticsAnalysisRun[]   @relation("GeneticsAnalysisCreatedBy")
  externalOperations   ExternalOperation[]     @relation("ExternalOperationCreatedBy")
  externalOperationLedgerEntries ExternalOperationLedgerEntry[] @relation("ExternalOperationLedgerCreatedBy")
  externalOperationSettlements  ExternalOperationSettlement[]   @relation("ExternalOperationSettlementCreatedBy")
  feedlotContracts     FeedlotContract[]       @relation("FeedlotContractCreatedBy")
  feedlotLedgerEntries FeedlotLedgerEntry[]    @relation("FeedlotLedgerCreatedBy")
  feedlotSettlements   FeedlotSettlement[]     @relation("FeedlotSettlementCreatedBy")
  reproCheckupSessions ReproCheckupSession[]   @relation("ReproCheckupCreatedBy")
  activeOrganization   Organization?           @relation("ActiveOrganization", fields: [activeOrganizationId], references: [id], onDelete: SetNull)
}

model Farm {
  id                 String                @id @default(uuid())
  name               String
  city               String
  lat                Float?
  lng                Float?
  size               Float
  notes              String?
  mapAssetPath       String?
  mapData            Json?
  organizationId     String?
  createdAt          DateTime              @default(now())
  reproMode          ReproMode             @default(CONTINUO)
  paddocks           Paddock[]
  lots               Lot[]
  animals            Animal[]
  seasons            BreedingSeason[]
  reproEvents        ReproEvent[]
  selectionDecisions SelectionDecision[]
  poAnimals          PoAnimal[]
  poLots             PoLot[]
  semenBatches       SemenBatch[]
  embryoBatches      EmbryoBatch[]
  poWeighings        PoWeighing[]
  paddockMoves       PaddockMove[]
  nutritionPlans     NutritionPlan[]
  nutritionAssignments NutritionAssignment[]
  nutritionSettings  NutritionSettings?
  nutritionPhases    NutritionPhase[]
  nutritionUnits     NutritionUnit[]
  nutritionIngredients NutritionIngredient[]
  nutritionPreparedFeeds NutritionPreparedFeed[]
  nutritionFabrications NutritionFabrication[]
  nutritionExecutions NutritionExecution[]
  nutritionTroughReadings NutritionTroughReading[]
  nutritionCostEntries NutritionCostEntry[]
  financialPayables  FinancialPayable[]
  financialReceivables FinancialReceivable[]
  criaMortalities    CriaMortality[]
  geneticsAnalysisRuns GeneticsAnalysisRun[]
  herdImportPendings HerdImportPending[]
  externalOperations ExternalOperation[]
  feedlotContracts   FeedlotContract[]
  reproCheckupSessions ReproCheckupSession[]
  reproCheckupRecords  ReproCheckupRecord[]
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  organization       Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([organizationId])
}

model Paddock {
  id               String        @id @default(uuid())
  name             String
  areaHa           Float?        @map("size")
  capacity         Float?
  lat              Float?
  lng              Float?
  mapGeometry      Json?
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  farm             Farm          @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId           String
  paddockMoves     PaddockMove[]
  currentAnimals   Animal[]      @relation("AnimalCurrentPaddock")
  currentPoAnimals PoAnimal[]    @relation("PoAnimalCurrentPaddock")

  @@index([farmId])
}

enum AnimalSexo {
  MACHO
  FEMEA
}

enum AnimalTipoCadastro {
  PO
  MESTICO
}

model Lot {
  id        String   @id @default(uuid())
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId    String
  animals   Animal[]
  nutritionAssignments NutritionAssignment[]
  nutritionUnits NutritionUnit[]
  nutritionExecutions NutritionExecution[]
  nutritionCostEntries NutritionCostEntry[]

  @@index([farmId])
}

model Animal {
  id             String             @id @default(uuid())
  brinco         String
  registro       String?
  identityKey    String
  raca           String?
  tipoCadastro   AnimalTipoCadastro @default(MESTICO)
  sexo           AnimalSexo?
  categoria      String?
  dataNascimento DateTime?
  pesoAtual      Float?
  gmd            Float?
  gmd30          Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  farm           Farm         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId         String
  lot            Lot?         @relation(fields: [lotId], references: [id], onDelete: SetNull)
  lotId          String?
  currentPaddock   Paddock    @relation("AnimalCurrentPaddock", fields: [currentPaddockId], references: [id], onDelete: Restrict)
  currentPaddockId String
  pesagens       Weighing[]
  exposures      Exposure[]
  reproEvents    ReproEvent[]
  selectionDecisions SelectionDecision[]
  nutritionAssignments NutritionAssignment[]
  paddockMoves   PaddockMove[]
  reproCheckupRecords ReproCheckupRecord[]
  criaMortalities CriaMortality[]

  @@index([farmId, brinco], map: "Animal_farmId_brinco_idx")
  @@unique([farmId, identityKey], map: "Animal_farmId_identityKey_key")
  @@index([farmId, registro], map: "Animal_farmId_registro_idx")
  @@index([farmId])
  @@index([lotId])
  @@index([currentPaddockId])
}

enum WeighingSource {
  MANUAL
  COIMMA
}

enum ScaleIntegrationProvider {
  COIMMA
}

model Weighing {
  id             String                   @id @default(uuid())
  data           DateTime
  peso           Float
  gmd            Float
  source         WeighingSource           @default(MANUAL)
  provider       ScaleIntegrationProvider?
  rawPayload     String?
  createdAt      DateTime                 @default(now())
  animal         Animal                   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId       String
  scaleSessionId String?

  @@unique([animalId, data])
  @@unique([scaleSessionId], map: "Weighing_scaleSessionId_key")
}

model CriaMortality {
  id         String    @id
  farmId     String
  animalId   String?
  poAnimalId String?
  category   String
  cause      String
  date       DateTime
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  farm       Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  animal     Animal?   @relation(fields: [animalId], references: [id], onDelete: SetNull)
  poAnimal   PoAnimal? @relation(fields: [poAnimalId], references: [id], onDelete: SetNull)

  @@index([animalId])
  @@index([farmId, date], map: "CriaMortality_farmId_date_idx")
  @@index([poAnimalId])
}

model Session {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?

  @@index([userId])
  @@index([expiresAt])
}


enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum BillingProvider {
  INTERNAL
  STRIPE
  ASAAS
  PAGARME
  MERCADOPAGO
}

enum BillingAccessState {
  ACTIVE
  TRIALING
  GRACE
  PAST_DUE
  BLOCKED
  CANCELED
}

enum BillingEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum FinancialPayableStatus {
  PENDING
  PAID
  CANCELED
}

enum FinancialReceivableStatus {
  PENDING
  RECEIVED
  CANCELED
}

enum ExternalAllocationType {
  INTERNAL
  EXTERNAL
}

enum ExternalLedgerEntryType {
  FREIGHT
  SANITARY_PROTOCOL
  ADVANCE
  MORTALITY
  MORTALITY_COMPENSATION
  MANUAL_DEBIT
  MANUAL_CREDIT
}

enum ExternalOperationDocumentType {
  SIGNED_CONTRACT
  WEIGHING_REPORT
  GTA
  NF
  OTHER
}

enum ExternalOperationNature {
  SERVICE
  GAIN_PARTNERSHIP
  CUSTOM_OPERATION
}

enum ExternalOperationStatus {
  DRAFT
  ACTIVE
  PARTIALLY_SETTLED
  SETTLED
  CANCELLED
}

enum ExternalPricingModel {
  ARROBA_PRODUCED
  HEAD_PER_DAY
  PERCENT_GAIN_SHARE
  CUSTOM_RULE
}

enum ExternalResponsibilityParty {
  OWNER
  OPERATOR
  SHARED
  CUSTOM
}

enum ExternalSettlementType {
  FINAL
  PARTIAL
}

enum FeedlotAttachmentType {
  WEIGHING_REPORT
  GTA
  NF
  OTHER
}

enum FeedlotContractStatus {
  DRAFT
  ACTIVE
  PARTIALLY_SETTLED
  SETTLED
  CANCELLED
}

enum FeedlotContractType {
  BOITEL_ARROBA
  PARCERIA_GANHO
}

enum FeedlotLedgerEntryType {
  FREIGHT
  SANITARY_PROTOCOL
  ADVANCE
  MORTALITY
  MORTALITY_COMPENSATION
  MANUAL_DEBIT
  MANUAL_CREDIT
}

enum FeedlotOperationAllocationType {
  INTERNAL
  EXTERNAL
}

enum FeedlotSettlementType {
  FINAL
  PARTIAL
}

model Organization {
  id                   String                         @id @default(uuid())
  name                 String
  slug                 String                         @unique
  billingProvider      BillingProvider                @default(INTERNAL)
  billingCustomerId    String?
  accessState          BillingAccessState             @default(ACTIVE)
  accessStateUpdatedAt DateTime                       @default(now())
  graceUntil           DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt
  memberships          OrganizationMembership[]
  farms                Farm[]
  activeUsers          User[]                         @relation("ActiveOrganization")
  entitlements         OrganizationProductEntitlement[]
  billingEvents        BillingEvent[]
  billingSubscriptions BillingSubscription[]
  geneticsAnalysisRuns GeneticsAnalysisRun[]

  @@index([accessState])
}

model Product {
  id           String                         @id @default(uuid())
  code         String                         @unique
  name         String
  description  String?
  isActive     Boolean                        @default(true)
  createdAt    DateTime                       @default(now())
  updatedAt    DateTime                       @updatedAt
  entitlements OrganizationProductEntitlement[]
}

model OrganizationProductEntitlement {
  id             String       @id @default(uuid())
  organizationId String
  productId      String
  status         String       @default("ACTIVE")
  startedAt      DateTime     @default(now())
  endedAt        DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([organizationId, productId])
  @@index([organizationId, status])
}

model OrganizationMembership {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

enum ReproMode {
  CONTINUO
  ESTACAO
}

enum ReviewStatus {
  PENDING
  APPROVED
}

enum NutritionOperationContext {
  CONFINAMENTO
  PASTO
  SEMI_CONFINAMENTO
}

enum NutritionAdjustmentMode {
  SUGESTAO
  REVISAO_OBRIGATORIA
  AUTOMATICO
}

enum NutritionUnitType {
  BAIA
  LOTE
  PONTO_TRATO
}

enum NutritionPreparedFeedStatus {
  ACTIVE
  INACTIVE
}

enum NutritionPlanLifecycleStatus {
  DRAFT
  ACTIVE
  ENDED
  ARCHIVED
}

enum NutritionFabricationStatus {
  PENDING
  APPROVED
  CANCELED
  REVERSED
}

enum NutritionReadingType {
  DIURNA
  NOTURNA
}

enum NutritionAnimalBehavior {
  RUMINANDO
  NORMAL
  INQUIETO
  APATICO
  OUTRO
}

enum ReproEventType {
  COBERTURA
  IATF
  DIAGNOSTICO_PRENHEZ
  PARTO
  DESMAME
}

enum SelectionDecisionType {
  KEEP
  WATCH
  DISCARD
}

enum EmbryoTechnique {
  FIV
  TE
}

enum SemenMoveType {
  IN
  OUT
  USE
  ADJUST
}

enum EmbryoMoveType {
  IN
  OUT
  TRANSFER
  ADJUST
}

model BreedingSeason {
  id        String      @id @default(uuid())
  farm      Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId    String
  name      String
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  exposures Exposure[]
  events    ReproEvent[]

  @@index([farmId, startAt])
}

model Exposure {
  id        String         @id @default(uuid())
  season    BreedingSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  seasonId  String
  animal    Animal         @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId  String
  createdAt DateTime       @default(now())

  @@unique([seasonId, animalId])
  @@index([animalId])
}

model ReproEvent {
  id        String          @id @default(uuid())
  farm      Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId    String
  animal    Animal          @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId  String
  type      ReproEventType
  date      DateTime
  season    BreedingSeason? @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  seasonId  String?
  payload   Json?
  notes     String?
  bullId    String?
  protocol  String?
  createdAt DateTime        @default(now())

  @@index([animalId, date])
  @@index([farmId, date])
  @@index([seasonId])
}

model SelectionDecision {
  id        String                 @id @default(uuid())
  farm      Farm                   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId    String
  animal    Animal                 @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId  String
  decision  SelectionDecisionType
  reason    String?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@unique([farmId, animalId])
  @@index([animalId])
  @@index([farmId])
}

model PoAnimal {
  id             String      @id @default(uuid())
  farm           Farm        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId         String
  brinco         String?
  nome           String
  raca           String
  sexo           AnimalSexo
  dataNascimento DateTime?
  pesoAtual      Float       @default(0)
  gmd            Float?
  gmd30          Float?
  lot            PoLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)
  lotId          String?
  currentPaddock   Paddock   @relation("PoAnimalCurrentPaddock", fields: [currentPaddockId], references: [id], onDelete: Restrict)
  currentPaddockId String
  registro       String?
  categoria      String?
  observacoes    String?
  criaMortalities CriaMortality[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  pesagens       PoWeighing[]
  semenBatches   SemenBatch[] @relation("SemenBull")
  embryoDonorBatches EmbryoBatch[] @relation("EmbryoDonor")
  embryoSireBatches EmbryoBatch[] @relation("EmbryoSire")
  nutritionAssignments NutritionAssignment[]
  paddockMoves   PaddockMove[]

  @@index([farmId])
  @@unique([farmId, brinco])
  @@index([lotId])
  @@index([currentPaddockId])
}

model PoLot {
  id        String   @id @default(uuid())
  name      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  farm      Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId    String
  animals   PoAnimal[]
  nutritionAssignments NutritionAssignment[]
  nutritionExecutions NutritionExecution[]
  nutritionCostEntries NutritionCostEntry[]

  @@index([farmId])
}

model PoWeighing {
  id         String   @id @default(uuid())
  data       DateTime
  peso       Float
  gmd        Float
  notes      String?
  createdAt  DateTime @default(now())
  poAnimal   PoAnimal @relation(fields: [poAnimalId], references: [id], onDelete: Cascade)
  poAnimalId String
  farm       Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId     String

  @@unique([poAnimalId, data])
  @@index([poAnimalId, data])
  @@index([farmId])
  @@index([farmId, data])
}

model NutritionPlan {
  id         String   @id @default(uuid())
  farm       Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId     String
  nome       String
  fase       String?
  objetivo   String?
  startAt    DateTime
  endAt      DateTime?
  metaGmd    Float?
  preparedFeedId String?
  phaseId    String?
  feedingSlot String?
  plannedIntakeNaturalKgPerHead Float?
  plannedIntakeDryKgPerHead Float?
  plannedIntakeNaturalKgTotal Float?
  plannedIntakeDryKgTotal Float?
  estimatedCostPerHeadDay Float?
  versionNumber Int @default(1)
  previousVersionId String?
  status     NutritionPlanLifecycleStatus @default(ACTIVE)
  observacoes String?
  reviewStatus ReviewStatus @default(PENDING)
  assignments NutritionAssignment[]
  preparedFeed NutritionPreparedFeed? @relation(fields: [preparedFeedId], references: [id], onDelete: SetNull)
  phase      NutritionPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  executions NutritionExecution[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([farmId])
  @@index([preparedFeedId])
  @@index([phaseId])
  @@index([status])
}

model NutritionAssignment {
  id         String   @id @default(uuid())
  farm       Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId     String
  plan       NutritionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId     String
  lot        Lot?     @relation(fields: [lotId], references: [id], onDelete: Cascade)
  lotId      String?
  poLot      PoLot?   @relation(fields: [poLotId], references: [id], onDelete: Cascade)
  poLotId    String?
  animal     Animal?  @relation(fields: [animalId], references: [id], onDelete: Cascade)
  animalId   String?
  poAnimal   PoAnimal? @relation(fields: [poAnimalId], references: [id], onDelete: Cascade)
  poAnimalId String?
  unit       NutritionUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  unitId     String?
  startAt    DateTime
  endAt      DateTime?
  reviewStatus ReviewStatus @default(PENDING)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([farmId])
  @@index([planId])
  @@index([lotId])
  @@index([poLotId])
  @@index([animalId])
  @@index([poAnimalId])
  @@index([unitId])
  @@index([farmId, startAt])
}

model NutritionSettings {
  id                         String                    @id @default(uuid())
  farmId                     String                    @unique
  operationContext           NutritionOperationContext @default(PASTO)
  adjustmentMode             NutritionAdjustmentMode   @default(SUGESTAO)
  indicatorsApprovedOnly     Boolean                   @default(false)
  requireFabricationApproval Boolean                   @default(true)
  requireExecutionApproval   Boolean                   @default(true)
  requireTroughApproval      Boolean                   @default(true)
  predictiveSafeDays         Int                       @default(7)
  predictiveWarningDays      Int                       @default(3)
  diffWarningPercent         Float                     @default(3)
  diffCriticalPercent        Float                     @default(7)
  manualReviewThresholdPercent Float                   @default(5)
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  farm                       Farm                      @relation(fields: [farmId], references: [id], onDelete: Cascade)
}

model NutritionPhase {
  id                    String          @id @default(uuid())
  farmId                String
  name                  String
  periodStart           DateTime?
  periodEnd             DateTime?
  primaryPlanId         String?
  targetIntakeDryKgHead Float?
  targetGmd             Float?
  targetFeedConversion  Float?
  targetCostPerHeadDay  Float?
  notes                 String?
  active                Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  farm                  Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  units                 NutritionUnit[]
  plans                 NutritionPlan[]

  @@index([farmId])
  @@index([active])
}

model NutritionUnit {
  id               String             @id @default(uuid())
  farmId           String
  lotId            String?
  phaseId          String?
  type             NutritionUnitType
  name             String
  currentHeadCount Int?
  active           Boolean            @default(true)
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  farm             Farm               @relation(fields: [farmId], references: [id], onDelete: Cascade)
  lot              Lot?               @relation(fields: [lotId], references: [id], onDelete: SetNull)
  phase            NutritionPhase?    @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  assignments      NutritionAssignment[]
  executions       NutritionExecution[]
  troughReadings   NutritionTroughReading[]

  @@index([farmId])
  @@index([lotId])
  @@index([phaseId])
  @@index([type])
}

model NutritionIngredient {
  id                     String                           @id @default(uuid())
  farmId                 String
  name                   String
  category               String
  unit                   String
  currentCost            Float
  supplier               String?
  currentDryMatterPercent Float
  dryMatterUpdatedAt     DateTime?
  currentStockNatural    Float                            @default(0)
  minStockNatural        Float                            @default(0)
  active                 Boolean                          @default(true)
  createdAt              DateTime                         @default(now())
  updatedAt              DateTime                         @updatedAt
  farm                   Farm                             @relation(fields: [farmId], references: [id], onDelete: Cascade)
  priceHistory           NutritionIngredientCostHistory[]
  dryMatterHistory       NutritionIngredientDryMatterHistory[]
  preparedFeedItems      NutritionPreparedFeedItem[]
  fabricationItems       NutritionFabricationItem[]

  @@index([farmId])
  @@index([active])
}

model NutritionIngredientCostHistory {
  id              String               @id @default(uuid())
  ingredientId    String
  cost            Float
  recordedAt      DateTime
  notes           String?
  createdByUserId String?
  createdByName   String?
  ingredient      NutritionIngredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([recordedAt])
}

model NutritionIngredientDryMatterHistory {
  id              String               @id @default(uuid())
  ingredientId    String
  dryMatterPercent Float
  recordedAt      DateTime
  notes           String?
  createdByUserId String?
  createdByName   String?
  ingredient      NutritionIngredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@index([ingredientId])
  @@index([recordedAt])
}

model NutritionPreparedFeed {
  id                    String                       @id @default(uuid())
  farmId                String
  name                  String
  expectedYieldNaturalKg Float
  expectedYieldDryKg    Float?
  currentDryMatterPercent Float
  currentTotalCost      Float
  currentCostPerNaturalKg Float
  currentCostPerDryKg   Float?
  currentStockNatural   Float                        @default(0)
  currentStockDry       Float                        @default(0)
  status                NutritionPreparedFeedStatus  @default(ACTIVE)
  notes                 String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  farm                  Farm                         @relation(fields: [farmId], references: [id], onDelete: Cascade)
  items                 NutritionPreparedFeedItem[]
  fabrications          NutritionFabrication[]
  plans                 NutritionPlan[]
  executions            NutritionExecution[]

  @@index([farmId])
  @@index([status])
}

model NutritionPreparedFeedItem {
  id             String                @id @default(uuid())
  preparedFeedId String
  ingredientId   String
  proportionPercent Float
  sequence       Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

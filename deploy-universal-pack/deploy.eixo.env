# deploy.eixo.env
# Configuração do projeto EIXO para deploy-universal.sh

PROJECT_NAME="EIXO"
PRODUCTION_URL="https://eixo.agr.br"

# Git local
LOCAL_BRANCH="main"
REMOTE_BRANCH="main"
GIT_REMOTE="origin"

# VPS
SSH_USER="root"
SSH_HOST="51.255.199.78"
REMOTE_DIR="/var/www/eixo"

# PM2
PM2_PROCESS="eixo-server"

# Frontend
FRONTEND_DIR="frontend"

# Ajuste local opcional do Vite
# Mantém o mesmo comportamento do deploy-local.sh antigo.
VITE_CONFIG="frontend/vite.config.ts"
DEV_API_TARGET="https://eixo.agr.br"
PROD_API_TARGET="http://localhost:3001"

# Validação local
LOCAL_VALIDATE_CMD="npx tsc -p frontend/tsconfig.json --noEmit"

# Servidor
RUN_INSTALL="0"
RUN_MIGRATIONS="0"

REMOTE_BUILD_CMD="cd frontend && npm run build && cd .."
REMOTE_RELOAD_CMD="pm2 reload eixo-server --update-env"

# Health check
HEALTHCHECK_URL="https://eixo.agr.br"

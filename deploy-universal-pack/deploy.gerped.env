# deploy.gerped.env
# Configuração do projeto GERPED para deploy-universal.sh
# Preencha os campos marcados antes de usar.

PROJECT_NAME="GERPED"
PRODUCTION_URL="https://SEU_DOMINIO_GERPED"

# Git local
LOCAL_BRANCH="main"
REMOTE_BRANCH="main"
GIT_REMOTE="origin"

# VPS
SSH_USER="root"
SSH_HOST="IP_DA_VPS_GERPED"
REMOTE_DIR="/var/www/gerped"

# PM2
PM2_PROCESS="gerped-server"

# Frontend
FRONTEND_DIR="frontend"

# Ajuste local opcional do Vite
# Se o GERPED não usa troca de vite.config.ts, deixe estas 3 linhas vazias.
VITE_CONFIG=""
DEV_API_TARGET=""
PROD_API_TARGET=""

# Validação local
# Ajuste conforme os scripts reais do GERPED.
LOCAL_VALIDATE_CMD="npx tsc -p frontend/tsconfig.json --noEmit"

# Servidor
RUN_INSTALL="0"
RUN_MIGRATIONS="0"

REMOTE_BUILD_CMD="cd frontend && npm run build && cd .."
REMOTE_RELOAD_CMD="pm2 reload gerped-server --update-env"

# Health check
HEALTHCHECK_URL="https://SEU_DOMINIO_GERPED"
